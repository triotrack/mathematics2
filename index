  useEffect(() => {
    // Inject MathJax Script if it doesn't exist
    if (!window.MathJax) {
      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js';
      script.async = true;
      document.head.appendChild(script);
    }
  }, []);

  // Typeset MathJax every time the module, mark, or reveal state changes
  useEffect(() => {
    if (window.MathJax) {
      // Small timeout to ensure React has updated the DOM
      setTimeout(() => {
        window.MathJax.typesetPromise();
      }, 50);
    }
  }, [activeModule, activeMark, revealedAnswers]);

  const toggleAnswer = (id) => {
    setRevealedAnswers(prev => ({ ...prev, [id]: !prev[id] }));
  };

  const currentQuestions = examData[activeModule].marks[activeMark];

  return (
    <div className="min-h-screen bg-slate-50 text-slate-800 font-sans pb-12">
      {/* Header */}
      <header className="bg-indigo-600 text-white shadow-lg sticky top-0 z-50">
        <div className="max-w-5xl mx-auto px-4 py-4 flex flex-col md:flex-row justify-between items-center gap-4">
          <div className="flex items-center gap-3">
            <Calculator className="w-8 h-8 text-indigo-200" />
            <div>
              <h1 className="text-2xl font-bold tracking-tight">SBTE Math II Pro</h1>
              <p className="text-indigo-200 text-sm">Exam Revision 2021 Syllabus</p>
            </div>
          </div>
          <div className="flex bg-indigo-700 rounded-lg p-1">
