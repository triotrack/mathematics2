                          : 'bg-green-50 text-green-700 hover:bg-green-100'
                      }`}
                    >
                      {isRevealed ? <EyeOff className="w-4 h-4" /> : <Eye className="w-4 h-4" />}
                      {isRevealed ? 'Hide Solution Steps' : 'View Step-by-Step Solution'}
                    </button>
                  </div>

                  {/* Solution Area */}
                  {isRevealed && (
                    <div className="p-6 border-t border-slate-100 bg-slate-50/50">
                      <div className="space-y-4">
                        {q.steps.map((step, stepIdx) => (
                          <div 
                            key={stepIdx} 
                            className={`p-4 rounded-lg flex gap-4 ${
                              stepIdx === q.steps.length - 1 
                                ? 'bg-indigo-50 border border-indigo-100' 
                                : 'bg-white border border-slate-200'
                            }`}
                          >
                            <div className="flex-shrink-0 mt-1">
                              {stepIdx === q.steps.length - 1 ? (
                                <CheckCircle className="w-5 h-5 text-green-500" />
                              ) : (
                                <div className="w-5 h-5 rounded-full bg-slate-200 text-slate-600 flex items-center justify-center text-[10px] font-bold">
                                  {stepIdx + 1}
                                </div>
                              )}
                            </div>
                            <div className="flex-1 overflow-x-auto math-display text-slate-700">
                              {step}
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              );
            })}
            
            {currentQuestions.length === 0 && (
              <div className="p-12 text-center bg-white rounded-xl border border-dashed border-slate-300">
                <p className="text-slate-500">More questions are being added to this category.</p>
              </div>
            )}
          </div>
        </section>
      </main>

      {/* Global Styles for Math Overflow */}
      <style dangerouslySetInnerHTML={{__html: `
        .math-display {
          overflow-x: auto;
          overflow-y: hidden;
          padding-bottom: 4px;
        }
        /* Scrollbar styling for math blocks */
        .math-display::-webkit-scrollbar {
          height: 6px;
        }
        .math-display::-webkit-scrollbar-track {
          background: #f1f5f9; 
          border-radius: 4px;
        }
        .math-display::-webkit-scrollbar-thumb {
          background: #cbd5e1; 
          border-radius: 4px;
        }
        .math-display::-webkit-scrollbar-thumb:hover {
          background: #94a3b8; 
        }
      `}} />
    </div>
  );
}
